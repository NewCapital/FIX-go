# FIX Environment Variables Example
# ====================================
# Copy this file to .env and fill in your values.
# Environment variables override values in YAML config files.
# Format: FIX_{SECTION}_{KEY} (uppercase, underscores)

# ==========================================
# Network Settings
# ==========================================
FIX_NETWORK=mainnet
FIX_NETWORK_PORT=17464
FIX_NETWORK_MAX_PEERS=125
FIX_NETWORK_LISTEN_ADDR=0.0.0.0
FIX_NETWORK_EXTERNAL_IP=
FIX_NETWORK_PROXY=
FIX_NETWORK_ONION_PROXY=

# ==========================================
# RPC Server Authentication
# ==========================================
# REQUIRED for production - use strong random credentials
FIX_RPC_ENABLED=true
FIX_RPC_USERNAME=
FIX_RPC_PASSWORD=
FIX_RPC_PORT=17465
FIX_RPC_HOST=127.0.0.1

# ==========================================
# Wallet Settings
# ==========================================
FIX_WALLET_DISABLED=false
FIX_WALLET_FILE=wallet.dat
FIX_WALLET_KEY_POOL=100
FIX_WALLET_TX_FEE=0.0001
FIX_WALLET_USE_HD=true
FIX_WALLET_RESCAN=false

# ==========================================
# Staking Settings
# ==========================================
FIX_STAKING_ENABLED=false
FIX_STAKING_RESERVE_BALANCE=0

# ==========================================
# Masternode Configuration
# ==========================================
FIX_MASTERNODE_ENABLED=false
FIX_MASTERNODE_KEY=
FIX_MASTERNODE_TIER=bronze
FIX_MASTERNODE_COLLATERAL_TX=
FIX_MASTERNODE_COLLATERAL_IDX=0
FIX_MASTERNODE_SERVICE_ADDR=
FIX_MASTERNODE_PAYMENT_ADDR=
FIX_MASTERNODE_DONATION_ADDR=
FIX_MASTERNODE_DONATION_PCT=0

# ==========================================
# Database Settings
# ==========================================
FIX_DATA_DIR=./data
FIX_DATABASE_TYPE=pebble
FIX_DATABASE_CACHE_SIZE=512
FIX_DATABASE_MAX_OPEN_FILES=1000
FIX_DATABASE_SYNC_WRITES=true
FIX_DATABASE_COMPRESSION=snappy

# ==========================================
# Logging Settings
# ==========================================
FIX_LOG_LEVEL=info
FIX_LOG_FORMAT=text
FIX_LOG_OUTPUT=./data/fix.log
FIX_LOG_MAX_SIZE=100
FIX_LOG_MAX_BACKUPS=3
FIX_LOG_COMPRESS=true
FIX_LOG_DEBUG_CATEGORIES=
